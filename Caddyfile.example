# HTTPS reverse proxy for the Axon Flask API (required for the production HTTPS PWA).
#
# Flask stays on http://127.0.0.1:1337
# Caddy serves https://<your-lan-ip>:8443
#
# Setup:
#   brew install caddy
#   ./scripts/caddy-https.sh
#
# The script auto-detects your LAN IP and writes Caddyfile before starting Caddy.
# iPhone URL: https://<your-lan-ip>:8443
# Railway:    VITE_AXON_API_URL=https://<your-lan-ip>:8443

{
	local_certs
}

https://<your-lan-ip>:8443, https://localhost:8443 {
	bind 0.0.0.0
	bind [::]
	reverse_proxy 127.0.0.1:1337
	tls internal
}