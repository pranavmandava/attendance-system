# kcc-app base URL (trpc-openapi REST + SSE stream)
# Local dev: http://localhost:3001  |  Production: https://app.korukondacoachingcentre.com
KCC_API_URL=http://localhost:3001

# Device identity — mint token via: cd kcc-app && bun run device:issue-token -- --device-id=kiosk-01
DEVICE_ID=kiosk-01
DEVICE_TOKEN=

# Flask API server (src/api/server.py) — defaults: debug off, 127.0.0.1:1337
# AXON_DEBUG=1
# AXON_HOST=127.0.0.1
# AXON_PORT=1337
